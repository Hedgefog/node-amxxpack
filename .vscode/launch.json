{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "inputs": [
    {
      "id": "projectDir",
      "description": "Enter path to test project directory",
      "type": "promptString"
    },
    {
      "id": "commandline",
      "description": "Enter command to run",
      "type": "promptString",
      "default": "help"
    }
  ],
  "configurations": [
    {
      "name": "Debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/ts-node",
      "runtimeArgs": [
        "-r", "tsconfig-paths/register"
      ],
      "program": "${workspaceFolder}/src/cli/index.ts",
      "args": "\"${input:commandline}\"",
      "cwd": "${input:projectDir}",
      "outputCapture": "std",
      "sourceMaps": true,
      "env": {
        "NODE_ENV": "development",
        "NODE_PATH": "${workspaceFolder}/node_modules",
        "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json",
        "RESOURCES_DIR": "${workspaceFolder}/resources",
      }
    },
    {
      "name": "Run Tests",
      "type": "node",
      "request": "launch",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/node_modules/jest/bin/jest.js",
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "RESOURCES_DIR": "${workspaceFolder}/resources"
      }
    }
  ]
}